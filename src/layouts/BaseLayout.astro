---
import Header from '../ui/astro/Header.astro'
import Footer from '../ui/astro/Footer.astro'
import type { Locale } from '../i18n/locales'
import { LOCALES } from '../i18n/locales'
import { ORIGINS, GOOGLE_FONTS_STYLESHEET } from '../config/appUrls'
import '../ui/styles/globals.css'
import '../ui/layouts/PublicLayout.css'

interface Props {
  locale: Locale
  title?: string
  /**
   * Oculta header y footer. Para páginas de flujo enfocado (p. ej. confirmar
   * cuenta), donde el usuario no debe navegar a ningún otro sitio.
   */
  hideChrome?: boolean
}

const { locale, title = 'KAI', hideChrome = false } = Astro.props
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/png" href="/kai_icona.png" />
    <title>{title}</title>
    <link rel="preconnect" href={ORIGINS.googleFonts} />
    <link rel="preconnect" href={ORIGINS.googleFontsStatic} crossorigin />
    <link href={GOOGLE_FONTS_STYLESHEET} rel="stylesheet" />
    {LOCALES.map((loc) => (
      <link rel="alternate" hreflang={loc} href={`/${loc}/`} />
    ))}
  </head>
  <body>
    <div class="public-layout">
      <a class="skip-link" href="#contenido">Saltar al contenido</a>
      {!hideChrome && <Header locale={locale} />}
      <main id="contenido" class="public-layout__main" tabindex="-1">
        <slot />
      </main>
      {!hideChrome && <Footer locale={locale} />}
    </div>

    <script>
      // Revela elementos [data-reveal] al entrar en el viewport (sustituye useScrollReveal).
      const motionOk = window.matchMedia('(prefers-reduced-motion: no-preference)').matches
      const targets = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'))
      if (motionOk && 'IntersectionObserver' in window && targets.length > 0) {
        targets.forEach((el) => el.classList.add('reveal'))
        const observer = new IntersectionObserver(
          (entries, obs) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible')
                obs.unobserve(entry.target)
              }
            }
          },
          { rootMargin: '0px 0px -5% 0px', threshold: 0.1 },
        )
        targets.forEach((el) => observer.observe(el))
      }
    </script>

    {locale === 'es' && (
      <script is:inline>
        // Redirect por idioma del navegador, solo en la primera visita de la sesión
        // y solo desde la raíz (es, sin prefijo). Reutiliza la clave kai:locale.
        ;(function () {
          const KEY = 'kai:locale'
          const SESSION_KEY = 'kai:locale-redirect-checked'
          if (sessionStorage.getItem(SESSION_KEY)) return
          sessionStorage.setItem(SESSION_KEY, '1')

          const stored = localStorage.getItem(KEY)
          const preferred = stored || (navigator.language || '').slice(0, 2).toLowerCase()
          if (preferred !== 'en' && preferred !== 'ca') return

          const path = window.location.pathname
          if (path.startsWith('/en') || path.startsWith('/ca')) return

          const bare = path.startsWith('/es') ? path.slice(3) || '/' : path
          const target = '/' + preferred + bare
          window.location.replace(target)
        })()
      </script>
    )}

    <script define:vars={{ locale }}>
      localStorage.setItem('kai:locale', locale)
    </script>
  </body>
</html>
