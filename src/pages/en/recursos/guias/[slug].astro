---
import BaseLayout from '../../../../layouts/BaseLayout.astro'
import GuidePage from '../../../../ui/astro/GuidePage.astro'
import { getContentRepository } from '../../../../modules/content/application/getContentRepository'

export async function getStaticPaths() {
  const repo = getContentRepository()
  const guides = await repo.getGuides('en')
  return guides.map((guide) => ({ params: { slug: guide.slug } }))
}

const { slug } = Astro.params
---

<BaseLayout locale="en" title="Guide · KAI">
  <GuidePage locale="en" slug={slug as string} />
</BaseLayout>
