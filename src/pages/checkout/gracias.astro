---
import BaseLayout from '../../layouts/BaseLayout.astro'

// SSR: leemos el session_id que Stripe añade al success_url.
export const prerender = false

const sessionId = Astro.url.searchParams.get('session_id')
---

<BaseLayout locale="es" title="Gracias por tu compra · KAI">
  <main class="checkout-thanks">
    <section class="checkout-thanks__card">
      <h1 class="checkout-thanks__title">¡Gracias por suscribirte a KAI!</h1>
      <p class="checkout-thanks__lead">
        Tu pago se está procesando. Recibirás la confirmación por correo en cuanto
        Stripe finalice la operación.
      </p>
      {sessionId && (
        <p class="checkout-thanks__ref">
          Referencia de sesión: <code>{sessionId}</code>
        </p>
      )}
      <a class="checkout-thanks__cta" href="/cuenta">Ir a mi cuenta</a>
    </section>
  </main>
</BaseLayout>

<style>
  .checkout-thanks {
    display: flex;
    justify-content: center;
    padding: 6rem 1.5rem;
  }
  .checkout-thanks__card {
    max-width: 34rem;
    text-align: center;
  }
  .checkout-thanks__title {
    font-size: 2rem;
    margin-bottom: 1rem;
  }
  .checkout-thanks__lead {
    opacity: 0.85;
    line-height: 1.6;
  }
  .checkout-thanks__ref {
    margin-top: 1.5rem;
    font-size: 0.85rem;
    opacity: 0.6;
    word-break: break-all;
  }
  .checkout-thanks__cta {
    display: inline-block;
    margin-top: 2rem;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    background: var(--color-primary, #635bff);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
  }
</style>
