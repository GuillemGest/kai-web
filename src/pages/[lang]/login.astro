---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { LoginApp } from '../../ui/islands/LoginApp'
import { PAGE_TITLES } from '../../i18n/titles'
import type { Locale } from '../../i18n/locales'

export function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'ca' } }]
}

const lang = Astro.params.lang as Locale
---

<BaseLayout locale={lang} title={PAGE_TITLES.login[lang]}>
  <LoginApp client:only="react" locale={lang} />
</BaseLayout>
