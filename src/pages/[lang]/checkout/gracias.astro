---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { PAGE_TITLES } from '../../../i18n/titles'
import { getLocaleUrl } from '../../../i18n/getLocaleUrl'
import { isLocale, DEFAULT_LOCALE } from '../../../i18n/locales'
import { CHECKOUT_THANKS_PAGE_CONTENT } from '../../../ui/pages/CheckoutThanksPage/content'

export function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'ca' } }]
}

const rawLang = Astro.params.lang
const lang = isLocale(rawLang) ? rawLang : DEFAULT_LOCALE
const content = CHECKOUT_THANKS_PAGE_CONTENT[lang]
// El session_id que Stripe añade al success_url se lee en cliente: Pages es
// estático, no hay SSR para leerlo en el servidor.
---

<BaseLayout locale={lang} title={PAGE_TITLES.checkoutThanks[lang]}>
  <main class="checkout-thanks">
    <section class="checkout-thanks__card">
      <h1 class="checkout-thanks__title">{content.title}</h1>
      <p class="checkout-thanks__lead">{content.lead}</p>
      <p class="checkout-thanks__ref" id="checkout-thanks-ref" hidden>
        {content.sessionRefLabel} <code id="checkout-thanks-session-id"></code>
      </p>
      <a class="checkout-thanks__cta" href={getLocaleUrl('/cuenta', lang)}>{content.ctaLabel}</a>
    </section>
  </main>
</BaseLayout>

<script>
  const sessionId = new URLSearchParams(window.location.search).get('session_id')
  if (sessionId) {
    const codeEl = document.getElementById('checkout-thanks-session-id')
    const refEl = document.getElementById('checkout-thanks-ref')
    if (codeEl) codeEl.textContent = sessionId
    if (refEl) refEl.hidden = false
  }
</script>

<style>
  .checkout-thanks {
    display: flex;
    justify-content: center;
    padding: 6rem 1.5rem;
  }
  .checkout-thanks__card {
    max-width: 34rem;
    text-align: center;
  }
  .checkout-thanks__title {
    font-size: 2rem;
    margin-bottom: 1rem;
  }
  .checkout-thanks__lead {
    opacity: 0.85;
    line-height: 1.6;
  }
  .checkout-thanks__ref {
    margin-top: 1.5rem;
    font-size: 0.85rem;
    opacity: 0.6;
    word-break: break-all;
  }
  .checkout-thanks__cta {
    display: inline-block;
    margin-top: 2rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--r-md, 0.5rem);
    background: var(--accent, #4cbdca);
    color: var(--bg, #2b2b2b);
    text-decoration: none;
    font-weight: 700;
  }
</style>
