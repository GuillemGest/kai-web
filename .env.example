# Copia este archivo a `.env.local` y rellena los valores (ese no se versiona).

# --- Stripe (modo TEST) ---
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # lo imprime `stripe listen`

# --- IDs de precio recurrente (price_...), por plan y periodo ---
STRIPE_PRICE_AUDIOPRO_MONTHLY=price_...
STRIPE_PRICE_AUDIOPRO_YEARLY=price_...
STRIPE_PRICE_FULLPRO_MONTHLY=price_...
STRIPE_PRICE_FULLPRO_YEARLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_YEARLY=price_...
